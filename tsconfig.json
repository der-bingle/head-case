{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "Bundler",
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"isolatedModules": true,
		"noEmit": true,
		"types": [
			"node"
		],
		"lib": [
			"DOM",
			"ES2020"
		]
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	]
}

